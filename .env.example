# Spruce app env (Vite — only VITE_* vars are exposed to the client)

# URL of the deployed Cloudflare Worker proxy.
# Local dev defaults to http://localhost:8787 (wrangler dev) when unset.
VITE_SPRUCE_PROXY_URL=http://localhost:8787

# Optional: app version string sent on requests + used for device registration.
VITE_APP_VERSION=0.1.0
